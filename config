# Modifier key (Super/Windows key)
set $mod Mod4

# Applications
set $term alacritty

# ====== Display Monitor
output eDP-1 resolution 1920x1200 pos 0 0
output HDMI-A-1 resolution 1920x1080 pos 1920 0

# ===== XWAYLAND SUPPORT =====
xwayland enable

# ===== INPUT CONFIGURATION =====
input type:keyboard {
	xkb_layout us
}

input type:pointer {
	accel_profile flat
	pointer_accel 0.3
}

# ===== APPEARANCE =====
gaps inner 1
gaps outer 1
# smart_gaps on
default_border pixel 2
default_floating_border normal
font pango:JetBrainsMono Nerd Font 12

# ===== COLORS =====
client.focused          #e5001c #0d0d0d #ffffff #e5001c #e5001c
client.unfocused        #1a1a1a #0a0a0a #555555 #1a1a1a #1a1a1a
client.focused_inactive #2a2a2a #111111 #888888 #2a2a2a #2a2a2a
client.urgent           #ff0028 #120000 #ffffff #ff0028 #ff0028
# ===== COLORS =====
# client.focused #4c7899 #285577 #ffffff #2e9ef4 #4c7899
# client.unfocused #333333 #222222 #888888 #292d2e #333333
# client.focused_inactive #333333 #5f676e #ffffff #484e50 #5f676e
# client.urgent #2f343a #900000 #ffffff #900000 #900000

# ===== APPLICATION KEYBINDINGS =====
bindsym $mod+Return exec $term
bindsym $mod+p exec ~/.config/sway/bin/monitor.sh
bindsym $mod+r exec google-chrome-stable
bindsym $mod+t exec telegram-desktop
bindsym $mod+w exec firefox
bindsym $mod+u exec discord
bindsym $mod+e exec thunar
bindsym $mod+n exec obsidian
bindsym $mod+y exec code
bindsym $mod+m exec chromium
bindsym $mod+b exec spotify
bindsym $mod+v exec caido
bindsym $mod+x exec copyq show
bindsym $mod+Space exec ulauncher-toggle
bindsym $mod+shift+d exec ~/.config/sway/bin/togglednd.sh

# ===== WINDOW MANAGEMENT =====
bindsym $mod+q kill
bindsym $mod+Shift+f fullscreen toggle
bindsym $mod+Shift+space floating toggle

# Focus movement
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
# Move windows
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
# Split directions
bindsym $mod+Shift+h splith
bindsym $mod+Shift+v splitv
# Focus parent
bindsym $mod+Shift+a focus parent

# Super+Tab to cycle in workspace
bindsym $mod+Tab focus next
bindsym $mod+Shift+Tab focus prev
floating_modifier $mod normal
# ===== LAYOUTS =====
bindsym $mod+Shift+s layout stacking
bindsym $mod+Shift+w layout tabbed
bindsym $mod+Shift+t layout toggle split


# ===== WORKSPACE NAMES =====
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# ===== WORKSPACE SWITCHING =====
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# To set specific
workspace $ws1 output eDP-1
workspace $ws2 output eDP-1
workspace $ws3 output eDP-1
workspace $ws4 output eDP-1
workspace $ws5 output eDP-1
workspace $ws6 output eDP-1
workspace $ws7 output eDP-1
workspace $ws8 output eDP-1
workspace $ws9 output eDP-1

#workspace $ws10 output HDMI-A-1
#workspace $ws10 output DP-3 

# Move to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Move workspaces between monitors
bindsym $mod+Control+Right move workspace to output right
bindsym $mod+Control+Left move workspace to output left
bindsym $mod+Control+Up move workspace to output up
bindsym $mod+Control+Down move workspace to output down

# ===== SCREENSHOTS & RECORDING =====
bindsym Print exec ~/.config/sway/bin/screenshot.sh window
bindsym Shift+Print exec ~/.config/sway/bin/screenshot.sh select 
bindsym F6 exec ~/.config/sway/bin/screenshot.sh select 

# ==== Touchpad & Airplane & Powermodes
bindsym F12 exec ~/.config/sway/bin/toggle-airplane-mode.sh  
bindsym F10 exec ~/.config/sway/bin/toggle-touchpad.sh
bindsym XF86Launch1 exec ~/.config/sway/bin/cycle-powermodes.sh  
input type:touchpad {
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
}

# ===== SYSTEM KEYBINDINGS =====
# Volume control
bindsym XF86AudioRaiseVolume exec ~/.config/sway/bin/volume.sh up
bindsym XF86AudioLowerVolume exec   ~/.config/sway/bin/volume.sh down
bindsym XF86AudioMute exec ~/.config/sway/bin/volume.sh toggle

# Mic
bindsym XF86AudioMicMute exec ~/.config/sway/bin/mictoggle.sh

# Brightness control
bindsym XF86MonBrightnessUp exec ~/.config/sway/bin/brightness.sh up
bindsym XF86MonBrightnessDown exec ~/.config/sway/bin/brightness.sh up
bindsym F8 exec ~/.config/sway/bin/brightness.sh up
bindsym F7 exec ~/.config/sway/bin/brightness.sh down

# Media control
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

bindsym F4 exec asusctl aura effect --next-mode
bindsym F2 exec asusctl leds next
bindsym F3 exec asusctl leds prev 

# Lock screen
bindsym $mod+Shift+l exec swaylock  -f -i $HOME/.config/sway/wallpaper/chess.png

# ===== SWAY CONTROL =====
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit Sway?' -B 'Yes' 'swaymsg exit'

# lock
# ===== RESIZE MODE =====
mode "resize" {
	bindsym Left resize shrink width 10px
	bindsym Down resize grow height 10px
	bindsym Up resize shrink height 10px
	bindsym Right resize grow width 10px
	bindsym Return mode "default"
	bindsym Escape mode "default"
}
bindsym $mod+Shift+r mode "resize"

# Dark theme
set $gnome-schema org.gnome.desktop.interface
exec_always gsettings set $gnome-schema color-scheme 'prefer-dark'
exec_always gsettings set $gnome-schema gtk-theme 'Adwaita-dark'
exec_always gsettings set $gnome-schema icon-theme 'Papirus-Dark'
exec_always gsettings set $gnome-schema cursor-theme 'Adwaita'

set $env QT_QPA_PLATFORMTHEME qt5ct
exec_always systemctl --user import-environment QT_QPA_PLATFORMTHEME
exec_always dbus-update-activation-environment --systemd QT_QPA_PLATFORMTHEME=qt5ct

# Assign apps to specific workspaces
assign [app_id="spotify"] $ws9
assign [class="discord"] $ws8
assign [app_id="obsidian"] $ws2
assign [app_id="org.telegram.desktop"] $ws1

# ===== FLOATING WINDOWS =====
#for_window [app_id="spotify"] floating enable, move position center, resize set 1200 800
for_window [app_id="copyq"] floating enable, resize set 600 600, move position 100% 0 px -600
for_window [app_id="ulauncher"] floating enable, border none, move position center, move up 200px
for_window [app_id="org.gnome.FileRoller"] floating enable, move position center
#for_window [app_id="org.telegram.desktop"] floating enable, move position center
#for_window [app_id="thunar"] floating enable, move position center, resize set 1200 800

# ===== AUTOSTART =====
exec_always ~/.config/sway/bin/workspace-outputs.sh
exec_always /home/7knights/.config/sway/bin/waybar_start.sh
exec_always swww-daemon
exec_always wl-paste -t text --watch clipman store --no-persis
exec_always copyq &
exec_always dunst &
bindswitch --reload --locked lid:on exec 'swaylock -f -i $HOME/.config/sway/wallpaper/chess.png; systemctl suspend'
exec_always nm-applet &
exec_always ulauncher &
exec_always libinput-gestures-setup start
exec rog-control-center &
exec udiskie --appindicator -t

# === Screensharing
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway XDG_SESSION_TYPE=wayland
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE
